# Copy to .env (gitignored) or set in your deploy env. No real values in git.
OPENROUTER_API_KEY=      # LLM (scene gen, profile, report) via OpenRouter
OPENAI_API_KEY=          # voice transcription (STT)
DEEPSEEK_API_KEY=        # optional alt LLM
GAOKAO_DATA_DIR=         # session-log sink dir (default /data/reflection-game/gaokao-data)
GAOKAO_LOG_SINK=         # optional off-box durable collector URL
GAOKAO_API_KEYS=         # comma-sep bearer keys; set => API requires a key (雨来 deploy); empty => open
GAOKAO_ADMIN_TOKEN=      # gates /prompts* and /rank_log
GAOKAO_RL_PER_HOUR=100   # per-IP rank_start cap/hour
YULAI_API_KEY=           # to call 雨来's evidence API for grounding
YULAI_BASE_URL=
